{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "node .cursor/hooks/gate-dev-workflow.mjs",
        "matcher": "Write|StrReplace|ApplyPatch|Delete|EditNotebook",
        "failClosed": true
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/gate-dev-shell.mjs",
        "matcher": ".*",
        "failClosed": true
      },
      {
        "command": "node .cursor/hooks/gate-toolchain-install.mjs",
        "matcher": ".*",
        "failClosed": true
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/gate-stop-workflow.mjs",
        "loop_limit": 3
      }
    ]
  }
}
