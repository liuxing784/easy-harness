{
  "version": 1,
  "gatedPaths": {
    "sourceDirs": [
      "src",
      "src-tauri",
      "app",
      "cmd",
      "lib",
      "internal",
      "pkg",
      "tests",
      "test",
      "__tests__",
      "spec",
      "components",
      "pages",
      "api",
      "services",
      "handlers",
      "crates",
      "backend",
      "frontend",
      "server",
      "client",
      "web",
      "mobile",
      "ios",
      "android",
      "infra",
      "infrastructure",
      "migrations",
      "db",
      "database"
    ],
    "buildManifests": [
      "package.json",
      "pyproject.toml",
      "go.mod",
      "Cargo.toml",
      "pom.xml",
      "build.gradle",
      "build.gradle.kts",
      "Gemfile",
      "composer.json",
      "CMakeLists.txt",
      "Makefile",
      "setup.py",
      "setup.cfg",
      "requirements.txt",
      "Pipfile",
      "mix.exs",
      "pubspec.yaml"
    ],
    "testConfigs": [
      "vitest.config.ts",
      "vitest.config.js",
      "jest.config.js",
      "jest.config.ts",
      "pytest.ini",
      "phpunit.xml",
      "playwright.config.ts",
      "cypress.config.ts",
      "karma.conf.js"
    ],
    "rootPatterns": [
      "Dockerfile*",
      "docker-compose*.yml",
      "docker-compose*.yaml",
      ".env*",
      ".github/**",
      ".gitlab-ci.yml",
      "Jenkinsfile",
      "Taskfile.yml",
      "justfile",
      "mise.toml",
      ".tool-versions",
      "openapi*.yaml",
      "openapi*.yml",
      "openapi*.json",
      "schema*.sql",
      "terraform/**",
      "helm/**",
      "k8s/**",
      "kubernetes/**"
    ],
    "docsAllowedExtensions": [".md", ".mdx", ".txt"]
  },
  "gatedShellPatterns": [
    "\\bnpm\\s+create\\b",
    "\\bnpm\\s+install\\b",
    "\\bnpm\\s+i\\b",
    "\\bnpm\\s+ci\\b",
    "\\bnpm\\s+add\\b",
    "\\bnpx\\s+create-",
    "\\bnpx\\s+@",
    "\\bpnpm\\s+create\\b",
    "\\bpnpm\\s+(install|i|add)\\b",
    "\\byarn\\s+create\\b",
    "\\byarn\\s+(install|add)\\b",
    "\\bbun\\s+(install|add|create)\\b",
    "\\bcargo\\s+init\\b",
    "\\bcargo\\s+new\\b",
    "\\bcargo\\s+add\\b",
    "create-tauri-app",
    "\\bnpm\\s+run\\s+tauri\\b",
    "\\bnpx\\s+tauri\\b",
    "\\bdotnet\\s+new\\b",
    "\\bdotnet\\s+add\\s+package\\b",
    "\\bdjango-admin\\s+startproject\\b",
    "\\bpip3?\\s+install\\b",
    "\\bpoetry\\s+init\\b",
    "\\bpoetry\\s+(add|install)\\b",
    "\\buv\\s+(init|add|sync|pip)\\b",
    "\\bconda\\s+install\\b",
    "\\bgo\\s+mod\\s+init\\b",
    "\\bgo\\s+get\\b",
    "\\bmvn\\s+archetype:generate\\b",
    "\\bgradle\\s+init\\b",
    "\\brails\\s+new\\b",
    "\\bflutter\\s+create\\b",
    "\\bflutter\\s+pub\\s+(get|add)\\b",
    "\\bdart\\s+pub\\s+(get|add)\\b",
    "\\bbundle\\s+init\\b",
    "\\bbundle\\s+install\\b",
    "\\bgem\\s+install\\b",
    "\\bcomposer\\s+create-project\\b",
    "\\bcomposer\\s+(install|require)\\b"
  ],
  "toolchain": {
    "approvalTtlMinutes": 60,
    "approvalMarkerFile": ".cursor/hooks/.toolchain-install-approved.json",
    "installPatterns": [
      "\\bwinget\\s+install\\b",
      "rustup-init",
      "\\bchoco\\s+install\\b",
      "\\bscoop\\s+install\\b",
      "\\bbrew\\s+install\\b",
      "\\bapt(-get)?\\s+install\\b",
      "\\byum\\s+install\\b",
      "\\bdnf\\s+install\\b",
      "\\bpacman\\s+-S\\b",
      "\\bzypper\\s+install\\b",
      "\\bnix\\s+(profile\\s+)?install\\b",
      "\\bnix-env\\s+-i\\b",
      "\\basdf\\s+install\\b",
      "\\bmise\\s+(install|use)\\b",
      "VisualStudio\\.\\*BuildTools",
      "VisualStudio\\.BuildTools",
      "vs_buildtools",
      "Microsoft\\.VisualStudio\\."
    ]
  },
  "workflowModes": {
    "full": "默认全流程（需求→设计→开发→QA→测试）",
    "hotfix": "热修复：跳过需求/架构，基于既有设计或最小设计直接进入开发",
    "docs-only": "仅文档变更：禁止写入源码目录",
    "single-task": "单任务包：压缩角色链，PM 一次分派 DE→QA→测试"
  },
  "defaultAgentModels": {
    "project-manager": "composer-2.5-fast",
    "requirements-analyst": "gpt-5.5-high",
    "system-architect": "claude-opus-4-8-thinking-high",
    "product-manager": "gpt-5.5-high",
    "development-engineer": "composer-2.5-fast",
    "quality-assurance-engineer": "gpt-5.3-codex",
    "test-engineer": "composer-2.5-fast"
  }
}
