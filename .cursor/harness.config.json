{
  "version": 1,
  "gatedPaths": {
    "sourceDirs": ["src"],
    "buildManifests": ["package.json"],
    "testConfigs": ["vitest.config.ts"],
    "rootPatterns": ["Dockerfile*"],
    "docsAllowedExtensions": [".md", ".mdx", ".txt"]
